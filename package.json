{
  "name": "@willbooster/react-frame-component",
  "version": "0.0.0-semantically-released",
  "description": "React component to wrap your application or component in an iFrame for encapsulation purposes",
  "keywords": [
    "React",
    "component",
    "iFrame",
    "browser"
  ],
  "homepage": "https://github.com/WillBooster/react-frame-component#readme",
  "bugs": {
    "url": "https://github.com/WillBooster/react-frame-component/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WillBooster/react-frame-component.git"
  },
  "license": "MIT",
  "author": "WillBooster Inc.",
  "contributors": [
    "Chris Trevino <darthtrevino@gmail.com>"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "build-ts lib",
    "build:example": "vite build --config vite.example.config.ts",
    "clean": "rimraf dist",
    "cleanup": "bun wb lint --fix --format",
    "format": "bun wb lint --format",
    "lint": "bun wb lint",
    "lint-fix": "bun wb lint --fix",
    "prepare": "lefthook install || true",
    "serve": "vite --root example",
    "start": "npm run serve",
    "test": "bun wb test",
    "test:watch": "vitest",
    "test/ci-setup": "playwright install --with-deps chromium firefox",
    "typecheck": "bun wb typecheck",
    "verify": "bun wb verify",
    "verify-full": "bun wb verify --full"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@tsconfig/bun": "1.0.10",
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/node-ts": "23.6.4",
    "@types/bun": "1.3.14",
    "@types/node": "26.1.0",
    "@types/prop-types": "15.7.15",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@willbooster/oxfmt-config": "1.2.2",
    "@willbooster/oxlint-config": "1.4.8",
    "@willbooster/wb": "15.3.0",
    "build-ts": "19.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "lefthook": "2.1.10",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "7.0.2001",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^5.0.5",
    "semantic-release": "^25.0.3",
    "sort-package-json": "4.0.0",
    "typescript": "7.0.2",
    "vite": "8.1.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "react": ">= 16.8 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": ">= 16.8 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
